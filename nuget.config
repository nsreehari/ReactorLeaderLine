<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Microsoft.UI.Reactor and Microsoft.WindowsAppSDK both resolve from
    nuget.org. We <clear /> first so authenticated user-level enterprise feeds
    from %APPDATA%\NuGet\NuGet.Config are not merged in and cannot stall
    restore on auth failures.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <disabledPackageSources>
    <clear />
  </disabledPackageSources>
</configuration>
